# polar-bear-arc-forge-defi - environment variable template
# Copy to .env and fill in real values.
# NEVER commit the .env file - it is gitignored.

# ── AI Agent (Rig / ARC) ──────────────────────────────────────────────────────
# Required only for --features ai-agent builds.
# Obtain at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Default: devnet (free, no real SOL required)
# Mainnet: https://api.mainnet-beta.solana.com
# Helius:  https://rpc.helius.xyz/?api-key=<KEY>
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Dry-run mode ──────────────────────────────────────────────────────────────
# Set to "true" to prevent any live transaction submission.
# This is the default and enforced in code - real SOL is never spent.
DRY_RUN=true

# ── Log level ─────────────────────────────────────────────────────────────────
# Options: error | warn | info | debug | trace
RUST_LOG=info
